generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// FORMATEUR
// ============================================================
model Teacher {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  status       String    @default("pending")  // "pending", "active", "rejected"
  createdAt    DateTime  @default(now())

  students           Student[]
  classes            Class[]
  comments           Comment[]
  missionAssignments MissionAssignment[]
}

// ============================================================
// CLASSE
// ============================================================
model Class {
  id        String   @id @default(cuid())
  code      String                      // ex: "NDRC1"
  name      String                      // ex: "BTS NDRC 1ère Année"
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId String
  createdAt DateTime @default(now())

  students  Student[]

  @@unique([code, teacherId])           // Un code unique par formateur
}

// ============================================================
// ÉLÈVE
// ============================================================
model Student {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  identifier   String   @unique          // ex: jean.dupont (auto-généré)
  passwordHash String                        // Mot de passe hashé avec bcrypt
  wpUrl        String?                        // URL du site WordPress de l'élève
  prestaUrl    String?                        // URL du site PrestaShop de l'élève
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId   String
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId     String
  createdAt   DateTime @default(now())

  progress  Progress[]
  comments  Comment[]
  missions  MissionAssignment[]

  @@unique([classId, firstName, lastName]) // Pas de doublon dans la même classe
}

// ============================================================
// PROGRESSION (1 ligne = 1 compétence validée)
// ============================================================
model Progress {
  id           String   @id @default(cuid())
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId    String
  competencyId String                   // ex: "wp-niv1-identite"
  acquired     Boolean  @default(false)
  status       Int      @default(0)       // 0=Non évalué, 1=Novice, 2=Apprenti, 3=Compétent, 4=Expert
  proof        String?                   // URL ou commentaire de l'élève
  updatedAt    DateTime @updatedAt

  @@unique([studentId, competencyId])   // 1 enregistrement par compétence par élève
}

// ============================================================
// COMMENTAIRES DU FORMATEUR
// ============================================================
model Comment {
  id        String   @id @default(cuid())
  text      String
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  createdAt DateTime @default(now())
}

// ============================================================
// MISSION (générée par IA ou créée manuellement)
// ============================================================
model Mission {
  id            String   @id @default(cuid())
  title         String
  content       String                        // Markdown de la mission
  platform      String                        // "WORDPRESS" | "PRESTASHOP"
  level         Int      @default(2)          // 1-4
  competencyIds String[]                      // IDs des compétences ciblées
  createdBy     String                        // ID Teacher ou Student
  createdByRole String                        // "TEACHER" | "STUDENT"
  createdAt     DateTime @default(now())

  assignments MissionAssignment[]
}

// ============================================================
// AFFECTATION DE MISSION
// ============================================================
model MissionAssignment {
  id          String    @id @default(cuid())
  mission     Mission   @relation(fields: [missionId], references: [id], onDelete: Cascade)
  missionId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId   String
  teacher     Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId   String
  status      String    @default("pending")   // "pending" | "in_progress" | "completed"
  assignedAt  DateTime  @default(now())
  completedAt DateTime?

  @@unique([missionId, studentId])
}
